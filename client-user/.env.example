# .env.example
# Copia este archivo a .env y ajusta las URLs según tu red local.
# Para probar con Expo Go en un dispositivo físico, usa la IP de tu
# computadora en la red local (no "localhost").

EXPO_PUBLIC_AUTH_URL=http://localhost:5166/api/v1
EXPO_PUBLIC_PASSENGER_URL=http://localhost:3011/urbus/v1
EXPO_PUBLIC_POST_URL=http://localhost:5001/urbus/v1
EXPO_PUBLIC_LOCATION_URL=http://localhost:3033
